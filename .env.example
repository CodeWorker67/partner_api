PARTNER_VPS_API_KEY=change-me-secret-key
API_HOST=0.0.0.0
API_PORT=8090
BOT_TEMPLATE_DIR=/root/bot_partner
INSTANCES_DIR=/root
DATABASE_DIR=/root/database
DATABASE_PATH=/root/database/partner.db
REGISTRY_PATH=/root/partner_api/registry.json
SHARED_ENV_PATH=/root/partner_api/shared.env
DEFAULT_TRIAL_DAYS=3

# Pull identity-настроек из Zoomer (тот же ключ, что PARTNER_BOT_API_KEY на мастере)
MASTER_BOT_API_URL=https://bot.zoomersky.online
MASTER_BOT_API_KEY=change-me-same-as-partner-bot-api-key
MASTER_BOT_API_TIMEOUT=45
